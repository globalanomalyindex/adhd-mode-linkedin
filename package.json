{
  "name": "adhd-mode-linkedin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A bounded LinkedIn Focus Session, coded interaction study, and product design case study.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/globalanomalyindex/adhd-mode-linkedin.git"
  },
  "homepage": "https://globalanomalyindex.github.io/adhd-mode-linkedin/",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "tokens:build": "style-dictionary build",
    "render:assets": "node scripts/render-assets.mjs",
    "validate:html": "html-validate index.html case-study/index.html prototype/demo.html",
    "check:links": "node scripts/check-local-links.mjs",
    "check:dashes": "node scripts/check-dashes.mjs",
    "serve": "node scripts/serve-static.mjs",
    "ci": "npm run test && npm run typecheck && npm run lint && npm run validate:html && npm run check:links && npm run check:dashes"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.11",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "html-validate": "^10.10.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sharp": "^0.34.5",
    "style-dictionary": "^5.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
