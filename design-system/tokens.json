{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "bg": {
      "$type": "color",
      "$value": "#f4f2ee"
    },
    "card": {
      "$type": "color",
      "$value": "#ffffff"
    },
    "brand": {
      "$type": "color",
      "$value": "#0a66c2"
    },
    "brand-hover": {
      "$type": "color",
      "$value": "#004182"
    },
    "brand-tint": {
      "$type": "color",
      "$value": "rgba(10, 102, 194, 0.04)"
    },
    "text": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.9)"
    },
    "text-secondary": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.6)"
    },
    "text-tertiary": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.45)"
    },
    "hairline": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.06)"
    },
    "hairline-2": {
      "$type": "color",
      "$value": "#e0dfdc"
    },
    "skip-grey": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.42)"
    },
    "skip-tint": {
      "$type": "color",
      "$value": "rgba(0, 0, 0, 0.06)"
    },
    "surface-2": {
      "$type": "color",
      "$value": "#f9fafb"
    },
    "field-grey": {
      "$type": "color",
      "$value": "#eef3f8"
    },
    "notify-red": {
      "$type": "color",
      "$value": "#cb112d"
    },
    "success-green": {
      "$type": "color",
      "$value": "#128161"
    },
    "react-insightful": {
      "$type": "color",
      "$value": "#fef3c7"
    },
    "react-support": {
      "$type": "color",
      "$value": "#ffedd5"
    },
    "react-love": {
      "$type": "color",
      "$value": "#fee2e2"
    },
    "react-celebrate": {
      "$type": "color",
      "$value": "#e0e7ff"
    }
  },
  "shadow": {
    "shadow": {
      "$type": "shadow",
      "$value": "0 0 0 1px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04)"
    },
    "shadow-hover": {
      "$type": "shadow",
      "$value": "0 0 0 1px rgba(0,0,0,0.10), 0 6px 16px rgba(0,0,0,0.06)"
    },
    "shadow-drag": {
      "$type": "shadow",
      "$value": "0 0 0 1px rgba(0,0,0,0.10), 0 12px 32px rgba(0,0,0,0.12)"
    }
  },
  "typography": {
    "font-sans": {
      "$type": "fontFamily",
      "$value": [
        "Source Sans 3",
        "-apple-system",
        "BlinkMacSystemFont",
        "sans-serif"
      ]
    },
    "fs-display": {
      "$type": "dimension",
      "$value": "32px"
    },
    "fs-heading": {
      "$type": "dimension",
      "$value": "20px"
    },
    "fs-body": {
      "$type": "dimension",
      "$value": "14px"
    },
    "fs-small": {
      "$type": "dimension",
      "$value": "13px"
    },
    "fs-meta": {
      "$type": "dimension",
      "$value": "12px"
    },
    "fs-tiny": {
      "$type": "dimension",
      "$value": "11px"
    },
    "fw-regular": {
      "$type": "fontWeight",
      "$value": 400
    },
    "fw-medium": {
      "$type": "fontWeight",
      "$value": 500
    },
    "fw-semibold": {
      "$type": "fontWeight",
      "$value": 600
    },
    "fw-bold": {
      "$type": "fontWeight",
      "$value": 700
    },
    "lh-tight": {
      "$type": "number",
      "$value": 1.15
    },
    "lh-base": {
      "$type": "number",
      "$value": 1.4
    },
    "lh-loose": {
      "$type": "number",
      "$value": 1.6
    },
    "tracking-tight": {
      "$type": "dimension",
      "$value": "-0.015em"
    },
    "tracking-wide": {
      "$type": "dimension",
      "$value": "0.04em"
    }
  },
  "space": {
    "1": {
      "$type": "dimension",
      "$value": "4px"
    },
    "2": {
      "$type": "dimension",
      "$value": "8px"
    },
    "3": {
      "$type": "dimension",
      "$value": "12px"
    },
    "4": {
      "$type": "dimension",
      "$value": "16px"
    },
    "5": {
      "$type": "dimension",
      "$value": "20px"
    },
    "6": {
      "$type": "dimension",
      "$value": "24px"
    },
    "7": {
      "$type": "dimension",
      "$value": "32px"
    },
    "8": {
      "$type": "dimension",
      "$value": "40px"
    },
    "9": {
      "$type": "dimension",
      "$value": "56px"
    }
  },
  "radius": {
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "8px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "12px"
    },
    "pill": {
      "$type": "dimension",
      "$value": "999px"
    }
  },
  "motion": {
    "duration": {
      "fast": {
        "$type": "duration",
        "$value": "150ms"
      },
      "base": {
        "$type": "duration",
        "$value": "240ms"
      },
      "slow": {
        "$type": "duration",
        "$value": "400ms"
      },
      "page": {
        "$type": "duration",
        "$value": "600ms"
      }
    },
    "easing": {
      "out": {
        "$type": "cubicBezier",
        "$value": [
          0.16,
          1,
          0.3,
          1
        ]
      },
      "in-out": {
        "$type": "cubicBezier",
        "$value": [
          0.4,
          0,
          0.2,
          1
        ]
      },
      "spring": {
        "$type": "cubicBezier",
        "$value": [
          0.34,
          1.56,
          0.64,
          1
        ]
      }
    },
    "lift": {
      "sm": {
        "$type": "dimension",
        "$value": "4px"
      },
      "md": {
        "$type": "dimension",
        "$value": "8px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "16px"
      }
    },
    "stagger": {
      "tight": {
        "$type": "duration",
        "$value": "40ms"
      },
      "loose": {
        "$type": "duration",
        "$value": "80ms"
      }
    }
  }
}
